# ===========================================================================
# voicebot — environment configuration (copy to .env and fill in)
# ===========================================================================

# ---- Bot pool range (inclusive) ----
START_BOT=1
END_BOT=1
START_DELAY_MS=4000

# ---- Minecraft server ----
SERVER_HOST=donutsmp.net
SERVER_PORT=25565
MC_VERSION=1.21

# ---- Microsoft auth (device-code; sessions cached under .msa-cache-<prefix>-<N>) ----
MSA_CACHE_PREFIX=adbot
MSA_LABEL=skellybot

# ---- Per-bot SOCKS5 proxy (any of the three casings is accepted) ----
# botproxy1=host:port@user:pass
# BOTPROXY1=host:port@user:pass

# ===========================================================================
# AI voice pipeline (voice_ai.js / voice_chat.js)
# ===========================================================================
# Required for AI conversations. Without these, voice is disabled but the
# join / tpahere / GUI-confirm flow still runs.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_LANGUAGE_CODE=en
ELEVENLABS_STT_MODEL=scribe_v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-5.2

# Simple Voice Chat behaviour
VOICEAD_REQUIRE_VC=true
USE_PROXY_UDP=true
SVC_COMPAT_VERSION=20

# ===========================================================================
# Discord
# ===========================================================================
VOICEAD_DISCORD_INVITE=discord.gg/donutty
VOICEAD_DC_VERIFY_CHANNEL_ID=
VOICEAD_DC_TEAM_CHANNEL_ID=
# Webhook for bot logs / recorded clips (VCBOTLOGS also accepted)
VCBOTLOGS=

# ===========================================================================
# Prompt files (optional — built-in fallbacks are used if these are missing).
# Copy prompts/*.example.txt to the repo root without the .example suffix,
# or point these at custom paths.
# ===========================================================================
VOICEAD_PROMPT_FILE=voicead_prompt.txt
VOICEAD_PITCH_PROMPT_FILE=voicead_pitch_prompt.txt
VOICEAD_GREETING_PROMPT_FILE=voicead_greeting_prompt.txt
VOICEAD_DISCORD_CONTEXT_FILE=voicead_discord_context.txt

# ===========================================================================
# Behaviour timing knobs (all optional — sensible defaults in src/config.js)
# ===========================================================================
# VOICEAD_SCAN_INTERVAL_MS=300000
# TPA_COMMAND=/tpahere
# TPA_WAIT_MS=30000
# RTPQUEUE_COMMAND=/rtpqueue
# CONVO_IDLE_MS=90000
# CONVO_MAX_MS=300000
# CONVO_COOLDOWN_MS=600000
# DEBUG=false
# TPAHERE=            # force a single target username for debugging
